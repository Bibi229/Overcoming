  m_GameObject: {fileID: 550462657}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6583ef5f43c332e47b0547db8e02c646, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  state: {fileID: 1976363612}
  inventory: {fileID: 1117563381}
  shopUI: {fileID: 2125578702}
  dialogueUI: {fileID: 550462657}
  text: {fileID: 402326987}
  sellerFace: {fileID: 1802352415}
  continueButton: {fileID: 1402966292}
  yesButton: {fileID: 535308551}
  noButton: {fileID: 1472498938}
  lines:
  - "\u0422\u044B... \u044F \u0442\u0435\u0431\u044F \u0437\u0434\u0435\u0441\u044C
    \u043D\u0435 \u0432\u0438\u0434\u0435\u043B \u0440\u0430\u043D\u044C\u0448\u0435"
  - "\u0422\u044B \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439?..."
  - "\u041B\u0430\u0434\u043D\u043E, \u043D\u0435 \u0432\u0430\u0436\u043D\u043E.
    \u041C\u043D\u0435 \u043D\u0443\u0436\u0435\u043D \u043E\u0434\u0438\u043D \u043F\u0440\u0435\u0434\u043C\u0435\u0442,
    \u0435\u0441\u043B\u0438 \u0442\u044B \u043F\u0440\u0438\u043D\u0435\u0441\u0435\u0448\u044C
    \u0435\u0433\u043E \u043C\u043D\u0435, \u0442\u043E \u043C\u043E\u0439 \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0447\u0438\u043A
    \u0441\u043D\u043E\u0432\u0430 \u0441\u043C\u043E\u0436\u0435\u0442 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C. "
  - "\u041A\u0430\u043A\u0430\u044F \u0442\u0435\u0431\u0435 \u043E\u0442 \u044D\u0442\u043E\u0433\u043E
    \u0432\u044B\u0433\u043E\u0434\u0430?... \u043D\u0443\u0443\u0443\u0443..."
  - "\u0422\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C \u043A\u0443\u043F\u0438\u0442\u044C
    \u043F\u043E\u043B\u0435\u0437\u043D\u044B\u0435 \u0448\u0442\u0443\u043A\u0438 "
  - "\u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0434\u0438, \u0442\u044B
    \u0442\u0440\u0430\u0442\u0438\u0448\u044C \u043C\u043E\u0435 \u0432\u0440\u0435\u043C\u044F"
